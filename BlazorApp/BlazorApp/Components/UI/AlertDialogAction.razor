@* AlertDialogAction *@
<button type="button" @onclick="HandleClick"
        class="inline-flex items-center justify-center rounded-md text-sm font-medium bg-primary text-primary-foreground hover:bg-primary/90 h-10 px-4 py-2 @Class">
    @ChildContent
</button>
@code {
    [CascadingParameter] public AlertDialog? Dialog { get; set; }
    [Parameter] public RenderFragment? ChildContent { get; set; }
    [Parameter] public string? Class { get; set; }
    [Parameter] public EventCallback OnClick { get; set; }
    private async Task HandleClick()
    {
        await OnClick.InvokeAsync();
        await (Dialog?.Hide() ?? Task.CompletedTask);
    }
}
