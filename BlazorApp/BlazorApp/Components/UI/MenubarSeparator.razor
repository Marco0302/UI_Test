@* MenubarSeparator.razor *@
<div role="separator" class="@CssClass" @attributes="AdditionalAttributes"></div>
@code {
    [Parameter] public string? Class { get; set; }
    [Parameter(CaptureUnmatchedValues = true)] public Dictionary<string, object>? AdditionalAttributes { get; set; }
    private string CssClass => string.Join(" ", "-mx-1 my-1 h-px bg-muted", Class ?? "").Trim();
}
