@* CarouselContent *@
<div class="overflow-hidden">
    <div class="flex @(Root?.Orientation == Carousel.CarouselOrientation.Vertical ? "-mt-4 flex-col" : "-ml-4") @Class"
         style="transform: @TranslateStyle; transition: transform 0.3s ease;">
        @ChildContent
    </div>
</div>

@code {
    [CascadingParameter] public Carousel? Root { get; set; }
    [Parameter] public RenderFragment? ChildContent { get; set; }
    [Parameter] public string? Class { get; set; }

    private string TranslateStyle =>
        Root?.Orientation == Carousel.CarouselOrientation.Vertical
            ? $"translateY(-{Root?.CurrentIndex * 100}%)"
            : $"translateX(-{Root?.CurrentIndex * 100}%)";
}
