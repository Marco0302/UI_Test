@* HoverCard.razor — equivalente ao hover-card.tsx (shadcn/ui) *@
@* Nota: O Radix HoverCard usa floating UI. Em Blazor fazemos com CSS :hover e posicionamento. *@

<div class="relative inline-block @Class" @attributes="AdditionalAttributes">
    <div @onmouseenter="Show" @onmouseleave="Hide">
        @Trigger
    </div>

    @if (_visible)
    {
        <div class="@ContentClass" style="@ContentStyle">
            @Content
        </div>
    }
</div>

@code {
    [Parameter] public RenderFragment? Trigger { get; set; }
    [Parameter] public RenderFragment? Content { get; set; }
    [Parameter] public string Align { get; set; } = "center"; // "start" | "center" | "end"
    [Parameter] public string Side { get; set; } = "bottom";  // "top" | "bottom" | "left" | "right"
    [Parameter] public string? Class { get; set; }
    [Parameter(CaptureUnmatchedValues = true)]
    public Dictionary<string, object>? AdditionalAttributes { get; set; }

    private bool _visible;

    private string ContentClass =>
        "absolute z-50 w-64 rounded-md border bg-popover p-4 text-popover-foreground shadow-md outline-none " +
        "animate-in fade-in-0 zoom-in-95";

    private string ContentStyle => Side switch
    {
        "top"    => "bottom: 100%; margin-bottom: 4px;" + AlignStyle,
        "left"   => "right: 100%; margin-right: 4px; top: 0;",
        "right"  => "left: 100%; margin-left: 4px; top: 0;",
        _        => "top: 100%; margin-top: 4px;" + AlignStyle, // bottom
    };

    private string AlignStyle => Align switch
    {
        "start" => " left: 0;",
        "end"   => " right: 0;",
        _       => " left: 50%; transform: translateX(-50%);", // center
    };

    private void Show() => _visible = true;
    private void Hide() => _visible = false;
}
