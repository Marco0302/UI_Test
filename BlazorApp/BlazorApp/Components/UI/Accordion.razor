@* Accordion - Componente raiz *@
<div class="@Class">
    <CascadingValue Value="this">
        @ChildContent
    </CascadingValue>
</div>

@code {
    [Parameter] public RenderFragment? ChildContent { get; set; }
    [Parameter] public string? Class { get; set; }
    [Parameter] public string? OpenItem { get; set; }
    [Parameter] public EventCallback<string?> OpenItemChanged { get; set; }

    public async Task Toggle(string value)
    {
        OpenItem = OpenItem == value ? null : value;
        await OpenItemChanged.InvokeAsync(OpenItem);
    }

    public bool IsOpen(string value) => OpenItem == value;
}
