@* Menubar.razor — equivalente ao menubar.tsx (shadcn/ui) *@

<div role="menubar" class="@CssClass" @attributes="AdditionalAttributes">
    <CascadingValue Value="this">
        @ChildContent
    </CascadingValue>
</div>

@code {
    [Parameter] public RenderFragment? ChildContent { get; set; }
    [Parameter] public string? Class { get; set; }
    [Parameter(CaptureUnmatchedValues = true)] public Dictionary<string, object>? AdditionalAttributes { get; set; }

    private string CssClass => string.Join(" ",
        "flex h-10 items-center space-x-1 rounded-md border bg-background p-1",
        Class ?? ""
    ).Trim();

    private string? _openMenu;

    internal void OpenMenu(string menuId)
    {
        _openMenu = menuId;
        StateHasChanged();
    }

    internal void CloseAll()
    {
        _openMenu = null;
        StateHasChanged();
    }

    internal bool IsOpen(string menuId) => _openMenu == menuId;
}
