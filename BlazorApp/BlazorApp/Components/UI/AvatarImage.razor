@* AvatarImage *@
<img src="@Src" alt="@Alt"
     class="aspect-square h-full w-full @Class"
     @onload="HandleLoad" @onerror="HandleError"
     style="@(failed ? "display:none" : "")" />

@code {
    [CascadingParameter] public Avatar? AvatarRoot { get; set; }
    [Parameter] public string? Src { get; set; }
    [Parameter] public string? Alt { get; set; }
    [Parameter] public string? Class { get; set; }

    private bool failed = false;

    private void HandleLoad() => AvatarRoot?.NotifyImageLoaded();
    private void HandleError() { failed = true; }
}
