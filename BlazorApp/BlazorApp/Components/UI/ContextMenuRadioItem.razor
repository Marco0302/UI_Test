@* ContextMenuRadioItem *@
<div role="menuitemradio"
     aria-checked="@(Value == GroupValue)"
     @onclick="HandleClick"
     class="relative flex cursor-default select-none items-center rounded-sm py-1.5 pl-8 pr-2 text-sm outline-none
            hover:bg-accent hover:text-accent-foreground
            @(Disabled ? "pointer-events-none opacity-50" : "")
            @Class">
    <span class="absolute left-2 flex h-3.5 w-3.5 items-center justify-center">
        @if (Value == GroupValue)
        {
            <svg xmlns="http://www.w3.org/2000/svg" class="h-2 w-2 fill-current" viewBox="0 0 24 24">
                <circle cx="12" cy="12" r="12"/>
            </svg>
        }
    </span>
    @ChildContent
</div>

@code {
    [CascadingParameter] public ContextMenuRadioGroup? RadioGroup { get; set; }
    [Parameter] public RenderFragment? ChildContent { get; set; }
    [Parameter] public string? Class { get; set; }
    [Parameter] public string Value { get; set; } = string.Empty;
    [Parameter] public bool Disabled { get; set; }

    private string? GroupValue => RadioGroup?.Value;

    private async Task HandleClick() => await (RadioGroup?.Select(Value) ?? Task.CompletedTask);
}
