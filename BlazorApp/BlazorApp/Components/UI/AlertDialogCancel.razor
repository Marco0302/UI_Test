@* AlertDialogCancel *@
<button type="button" @onclick="HandleClick"
        class="inline-flex items-center justify-center rounded-md text-sm font-medium border border-input bg-background hover:bg-accent hover:text-accent-foreground h-10 px-4 py-2 mt-2 sm:mt-0 @Class">
    @ChildContent
</button>
@code {
    [CascadingParameter] public AlertDialog? Dialog { get; set; }
    [Parameter] public RenderFragment? ChildContent { get; set; }
    [Parameter] public string? Class { get; set; }
    private async Task HandleClick() => await (Dialog?.Hide() ?? Task.CompletedTask);
}
