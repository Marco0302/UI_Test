@* Badge *@
<div class="inline-flex items-center rounded-full border px-2.5 py-0.5 text-xs font-semibold transition-colors focus:outline-none focus:ring-2 focus:ring-ring focus:ring-offset-2 @VariantClass @Class">
    @ChildContent
</div>

@code {
    [Parameter] public RenderFragment? ChildContent { get; set; }
    [Parameter] public string? Class { get; set; }
    [Parameter] public BadgeVariant Variant { get; set; } = BadgeVariant.Default;

    private string VariantClass => Variant switch
    {
        BadgeVariant.Secondary    => "border-transparent bg-secondary text-secondary-foreground hover:bg-secondary/80",
        BadgeVariant.Destructive  => "border-transparent bg-destructive text-destructive-foreground hover:bg-destructive/80",
        BadgeVariant.Outline      => "text-foreground",
        _                         => "border-transparent bg-primary text-primary-foreground hover:bg-primary/80"
    };

    public enum BadgeVariant { Default, Secondary, Destructive, Outline }
}
