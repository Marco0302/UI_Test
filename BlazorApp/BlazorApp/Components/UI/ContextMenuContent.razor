@* ContextMenuContent *@
@if (Root?.IsOpen == true)
{
    <div @onclick:stopPropagation="true">
        @* Backdrop to close *@
        <div class="fixed inset-0 z-40" @onclick="() => Root?.Close()"></div>
        <div class="fixed z-50 min-w-[8rem] overflow-hidden rounded-md border bg-popover p-1 text-popover-foreground shadow-md @Class"
             style="left: @(Root?.X)px; top: @(Root?.Y)px;">
            @ChildContent
        </div>
    </div>
}

@code {
    [CascadingParameter] public ContextMenu? Root { get; set; }
    [Parameter] public RenderFragment? ChildContent { get; set; }
    [Parameter] public string? Class { get; set; }
}
