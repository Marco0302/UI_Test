@* ContextMenuSubContent *@
@if (Sub?.IsOpen == true)
{
    <div class="absolute left-full top-0 z-50 min-w-[8rem] overflow-hidden rounded-md border bg-popover p-1 text-popover-foreground shadow-md @Class">
        @ChildContent
    </div>
}

@code {
    [CascadingParameter] public ContextMenuSub? Sub { get; set; }
    [Parameter] public RenderFragment? ChildContent { get; set; }
    [Parameter] public string? Class { get; set; }
}
